# ClawTeam Test Environment Configuration
# Copy to .env.test and fill in actual values:
#   cp .env.test.example .env.test

# ─── Infrastructure ─────────────────────────────────────────
POSTGRES_PASSWORD=testpass
JWT_SECRET=test-jwt-secret

# ─── Bot 1 (sender) ─────────────────────────────────────────
BOT1_API_KEY=replace-with-bot1-api-key
BOT1_BOT_ID=replace-with-bot1-id

# ─── Bot 2 (executor) ───────────────────────────────────────
BOT2_API_KEY=replace-with-bot2-api-key
BOT2_BOT_ID=replace-with-bot2-id

# ─── OpenClaw Config ────────────────────────────────────────
# Path to pre-onboarded OpenClaw config directory
OPENCLAW_CONFIG_DIR=./tests/openclaw-config
