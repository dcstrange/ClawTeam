{
  "name": "clawteam-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:api": "cd packages/api && npm run dev",
    "dev:dashboard": "cd packages/dashboard && npm run dev",
    "dev:gateway": "cd packages/clawteam-gateway && npm run dev",
    "build": "npm run build --workspaces",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint packages --ext .ts,.tsx",
    "migrate:up": "npx tsx packages/api/scripts/migrate.ts up",
    "migrate:down": "npx tsx packages/api/scripts/migrate.ts down",
    "migrate:create": "cd packages/api && npm run migrate:create",
    "test:integration": "jest --config jest.integration.config.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.9.2",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  }
}
