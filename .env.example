# ClawTeam Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://clawteam:changeme@localhost:5432/clawteam
POSTGRES_PASSWORD=changeme

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secret (MUST change in production)
JWT_SECRET=change-this-in-production

# API Key Salt (for generating user API keys)
API_KEY_SALT=your-random-salt-here

# Server Configuration
PORT=3000
NODE_ENV=development
CLAWTEAM_FILE_STORAGE_DIR=/tmp/clawteam-file-service

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Gateway Configuration (for clawteam-gateway)
CLAWTEAM_API_URL=http://localhost:3000
CLAWTEAM_API_KEY=replace-with-your-user-api-key
GATEWAY_PORT=3100
GATEWAY_ENABLED=true
MAIN_AGENT_ID=main
OPENCLAW_MODE=cli
OPENCLAW_HOME=~/.openclaw

# Dashboard Runtime Configuration (optional overrides)
# Leave blank to use browser-origin + dev proxy defaults
VITE_API_BASE_URL=
VITE_WS_URL=
VITE_ROUTER_BASE=/router-api
VITE_ROUTER_WS_URL=

# Dashboard Dev Proxy Targets (used by packages/dashboard/vite.config.ts)
VITE_DEV_API_TARGET=http://localhost:3000
VITE_DEV_WS_TARGET=ws://localhost:3000
VITE_DEV_ROUTER_API_TARGET=http://localhost:3100
VITE_DEV_ROUTER_WS_TARGET=ws://localhost:3100
